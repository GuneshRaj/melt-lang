struct PriceRow:
    ts: Int64
    close: Float32

kernel fn scale(x: Array[Float32], factor: Float32) -> Array[Float32]:
    return x.map(v -> v * factor)

fn main():
    rows = csv.load("data/prices_1m.csv", as=Array[PriceRow])
    close = rows.map(r -> r.close)
    out = scale(close, 1.1)
    csv.save("build/out_gpu_scale_1m_f32.csv", out)
